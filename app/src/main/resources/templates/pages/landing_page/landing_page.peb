<!DOCTYPE html>
<html lang="en" th:fragment="layout(title, content)">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title th:replace="${title}">NourishLog</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
{% extends "layouts/base.peb" %}
{% block content %}
<div class="page-wrapper">

    <div style="text-align:center; max-width:700px; margin:0 auto;">

        <h1>Title_of_name</h1>

        <p>
            introduction
        </p>

        <div style="margin-top:30px;">

            <a href="/Login" class="btn btn-primary" style="font-size:1.2rem;padding:1rem 3rem;">
                Login
            </a>

            <a href="/Sign-Up" class="btn btn-secondary" style="font-size:1.2rem;padding:1rem 3rem;margin-left:20px;">
                Sign Up
            </a>

        </div>

    </div>

</div>
{% endblock %}
</html>