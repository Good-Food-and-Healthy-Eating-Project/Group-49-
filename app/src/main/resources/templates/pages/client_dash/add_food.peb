<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Food</title>
    <link rel="stylesheet" href="/static/css/style.css">
    <style>
        .add-food-container {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 20px;
            padding: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .calorie-section {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .section-title {
            font-size: 20px;
            font-weight: 600;
            color: #333;
        }

        .info-box {
            border: 2px solid #bdbdbd;
            padding: 20px;
            min-height: 300px;
            background: #ffffff;
        }

        .meals {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .mode-section {
            border: 2px solid #bdbdbd;
            padding: 15px;
            background: #ffffff;
        }

        .mode-content {
            margin-bottom: 10px;
        }

        .mode-label {
            font-size: 14px;
            color: #666;
            padding: 8px;
            border: 1px solid #e0e0e0;
            border-radius: 4px;
            display: inline-block;
        }
    </style>
</head>
<body>
    {% include "components/navbar.peb" %}

    <main class="main-content">
        <div class="add-food-container">

            <div class="calorie-section">
                <h2 class="section-title">Calorie Info</h2>
                <div class="info-box">
                    {% if calories is defined %}
                        <p>Total Calories: {{ calories }}</p>
                    {% else %}
                        <p>No calories calculated yet.</p>
                    {% endif %}
                    {% if protein is defined %}
                        <p>Total Protein: {{ protein }} g</p>
                    {% endif %}
                    {% if carbs is defined %}
                        <p>Total Carbs: {{ carbs }} g</p>
                    {% endif %}
                    {% if fat is defined %}
                        <p>Total Fat: {{ fat }} g</p>
                    {% endif %}
                </div>
                <form method="post" action="/food_log_reset">
                    <button type="submit">Reset</button>
                </form>

                <form method="post" action="/save_meal">
                    <input type="text" name="mealName" placeholder="Meal name" required>
                    <button type="submit">Save meal</button>
                </form>
            </div>

            <!-- RIGHT: Recipes + Custom -->
            <div class="meals">

                <!-- RECIPES SECTION -->
                <div class="mode-section">
                    <h3 class="section-title">Meals</h3>

                    <!-- SEARCH -->
                    <div class="mode-content">
                        <form method="get" action="/food_log">
                            <input type="text" name="query" placeholder="Search recipes">
                            <button type="submit">Search</button>
                        </form>
                    </div>

                    
                    <form method="post" action="/food_log_recipe">
                        <div class="mode-content">
                            {% if recipes is not empty %}
                                {% for r in recipes %}
                                    <label>
                                        <input type="radio" name="recipeId" value="{{ r.id }}">
                                        {{ r.name }}
                                    </label><br>
                                {% endfor %}
                            {% else %}
                                <p>No recipes found</p>
                            {% endif %}
                        </div>

                        <button type="submit">Add</button>
                    </form>
                </div>

                <!-- CUSTOM SECTION -->
                <div class="mode-section">
                    <h3 class="section-title">Custom</h3>

                    <div class="mode-content">
                        <form method="get" action="/food_log">
                            <input type="text" name="foodquery" placeholder="Food name">
                            <button type="submit">Search</button>
                        </form>
                    </div>
                    <form method="post" action="/food_log_custom">
                        <div class="mode-content">
                            {% if foods is not empty %}
                                {% for f in foods %}
                                    <label>
                                        <input type="radio" name="foodId" value="{{ f.id }}" required>
                                            {{ f.name }}
                                    </label><br>
                                {% endfor %}
                                <input type="number" name="grams" placeholder="Grams" min="1" required>
                            {% else %}
                                <p>No foods found</p>
                            {% endif %}
                        </div>
                        <button type="submit">Add</button>
                    </form>
                </div>
                <!-- SAVED MEALS SECTION -->
                <div class="mode-section">
                    <h3 class="section-title">Saved Meals</h3>

                    <form method="post" action="/add_saved_meal_to_log">
                        <div class="mode-content">
                            {% if savedMeals is not empty %}
                                {% for meal in savedMeals %}
                                    <label>
                                        <input type="radio" name="mealId" value="{{ meal.id }}" required>
                                        {{ meal.name }}
                                    </label><br>
                                {% endfor %}
                            {% else %}
                                <p>No saved meals found</p>
                            {% endif %}
                        </div>

                        <button type="submit">Add saved meal</button>
                    </form>
                </div>
            </div>
        </div>
    </main>

</body>
</html>