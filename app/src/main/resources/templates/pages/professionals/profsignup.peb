<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Professional Sign Up</title>
	<style>
		body {
			margin: 0;
			font-family: Arial, sans-serif;
			background: #f5f5f5;
		}

		.outer-frame {
			max-width: 980px;
			margin: 40px auto;
			border: 2px solid #bdbdbd;
			padding: 28px;
			background: #ffffff;
		}

		.inner-frame {
			border: 2px solid #bdbdbd;
			padding: 28px;
			min-height: 360px;
			box-sizing: border-box;
		}

		.title {
			margin: 0 0 36px 0;
			font-size: 28px;
			font-weight: 500;
			color: #333333;
		}

		.field-group {
			margin-bottom: 28px;
			max-width: 620px;
		}

		label {
			display: block;
			margin-bottom: 10px;
			font-size: 26px;
			color: #333333;
		}

		input[type="text"],
		input[type="email"],
		input[type="password"] {
			width: 100%;
			height: 54px;
			box-sizing: border-box;
			border: 2px solid #bdbdbd;
			font-size: 22px;
			padding: 0 12px;
			background: #ffffff;
		}

		.actions {
			margin-top: 12px;
		}

		button {
			height: 44px;
			min-width: 120px;
			border: 2px solid #bdbdbd;
			background: #ffffff;
			font-size: 18px;
			cursor: pointer;
		}
	</style>
</head>
<body>
	<div class="outer-frame">
		<div class="inner-frame">
			<h1 class="title">Professional Sign Up</h1>
			{% if success %}
				<p style="color: green;">Successfully signed up</p>
				<p><a href="/Professional-Login">Go to login</a></p>
			{% endif %}

			{% if error %}
				<p style="color: red;">{{ error }}</p>
			{% endif %}

			<form action="/Professional-Sign-Up" method="post">
				<div class="field-group">
					<label for="email">email</label>
					<input id="email" name="email" type="email" required>
				</div>

				<div class="field-group">
					<label for="password">Password</label>
					<input id="password" name="password" type="password" required>
				</div>

				<div class="actions">
					<button type="submit">Sign Up</button>
				</div>
			</form>
		</div>
	</div>
</body>
</html>
