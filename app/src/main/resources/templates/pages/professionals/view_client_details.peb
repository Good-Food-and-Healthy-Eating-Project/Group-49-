{% extends "layouts/base.peb" %}

{% block title %}{{ pageTitle | default("View Client Details") }}{% endblock %}

{% block content %}

    <h1>Client Overview</h1>

    <p>Name: {{ client.firstName }} {{ client.lastName }}</p>
    <p>Email: {{ client.email }}</p>
    <p>Goal: {{ client.goal }}</p>
    <p>Daily Calorie Target: {{ client.calorieGoal }} kcal</p>
    <p>Age: {{ client.age }}</p>
    <p>Gender: {{ client.gender }}</p>

    <div class="client-summary" style="margin: 20px 0; padding: 16px; border: 2px solid #8C7B6A; border-radius: 12px; background: #FDFAF5; display: inline-block;">
        <h2 style="margin-top: 0;">Monthly Summary</h2>
        <p>On track: <strong>{{ onTrackDays }} / {{ totalTrackedDays }}</strong> days this month
            <span style="font-size: 13px; color: #4A3F35;">(within 100 kcal of target)</span>
        </p>
        <p>Today: <strong>{{ todayCalories }} kcal</strong> / {{ client.calorieGoal }} kcal target</p>
    </div>

    <div class="calendar-widget" style="width: auto; min-width: 340px; margin-top: 20px;">
        <div class="calendar-navigation">
            <a href="/professional/client/{{ client.clientId }}?year={{ previousYear }}&month={{ previousMonth }}" class="calendar-nav-button">&laquo; Prev</a>
            <h2>{{ currentYear }} / {{ currentMonth }}</h2>
            <a href="/professional/client/{{ client.clientId }}?year={{ nextYear }}&month={{ nextMonth }}" class="calendar-nav-button">Next &raquo;</a>
        </div>
        <div class="calendar-weekdays" style="margin-top: 12px;">
            <div>Mon</div>
            <div>Tue</div>
            <div>Wed</div>
            <div>Thu</div>
            <div>Fri</div>
            <div>Sat</div>
            <div>Sun</div>
        </div>
        <div class="calendar-grid">
            {# Push day 1 to the right weekday column — leadingEmptyDays comes from backend (dayOfWeek - 1) #}
            {% for i in 1..leadingEmptyDays %}
                <div class="day-cell empty-cell"></div>
            {% endfor %}
            {% for day in 1..daysInMonth %}
                {# found tracks whether this day has diet data — used to show empty-day style if no log entry #}
                {% set found = false %}
                <div class="day-cell">
                    {% for trend in trends %}
                        {% if trend.dayOfMonth == day %}
                            {% set found = true %}
                            {# numberformat("0") removes decimal places from the calorie value #}
                            {# colourClass is set in the backend based on how close calories were to target #}
                            <div class="day-box {{ trend.colourClass }}">
                                {{ day }}
                                <div class="tooltip">
                                    Kcal: {{ trend.totalCalorie | numberformat("0") }} / {{ trend.targetCalorie }}
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                    {# No log entry for this day — show it as untracked #}
                    {% if not found %}
                        <div class="day-box empty-day">
                            {{ day }}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
        {% if trends is empty %}
            <div class="no-data">No diet data for this month</div>
        {% endif %}
    </div>

    <div style="max-width: 700px; margin: 20px 0; padding: 16px; border: 1px solid #EDE6D8; border-radius: 12px; background: #FDFAF5;">
        <h2 style="margin-top: 0; font-size: 1.1rem;">Calorie Trend </h2>
        <canvas id="calorieChart"></canvas>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Chart.js library used because:
        // Chosen because it is very simple to use due to limited time to learn other methods
        // Works very well with JS and HTML
        // Claude AI used to learn how to create simple line graph function
        // Last 7 days — day numbers as labels (e.g. 29, 30, 1, 2, 3, 4, 5), calories pre-calculated in backend
        // 0 means the client had no diary entry that day
        const labels = [{% for d in weekLabels %}"{{ d }}"{% if not loop.last %},{% endif %}{% endfor %}];
        const actual = [{% for c in weekCalories %}{{ c }}{% if not loop.last %},{% endif %}{% endfor %}];
        // target is the same value every day (client's daily calorie goal) — shown as a flat dashed line
        const target = [{% for d in weekLabels %}{{ client.calorieGoal }}{% if not loop.last %},{% endif %}{% endfor %}];
        const protein = [{% for p in weekProtein %}{{ p }}{% if not loop.last %},{% endif %}{% endfor %}];
        const carbs = [{% for c in weekCarbs %}{{ c }}{% if not loop.last %},{% endif %}{% endfor %}];
        const fat = [{% for f in weekFat %}{{ f }}{% if not loop.last %},{% endif %}{% endfor %}];

        new Chart(document.getElementById('calorieChart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Calories eaten',
                        data: actual,
                        borderColor: '#A94F24',
                        backgroundColor: 'rgba(169, 79, 36, 0.08)',
                        fill: true,
                        tension: 0.3,
                        pointRadius: 4,
                    },
                    {
                        label: 'Target',
                        data: target,
                        borderColor: '#7A8C72',
                        borderDash: [6, 4],
                        pointRadius: 0,
                        fill: false,
                    },
                    {
                        label: 'Protein (g)',
                        data: protein,
                        borderColor: '#4A90D9',
                        pointRadius: 4,
                        fill: false,
                        tension: 0.3,
                    },
                    {
                        label: 'Carbs (g)',
                        data: carbs,
                        borderColor: '#E8A838',
                        pointRadius: 4,
                        fill: false,
                        tension: 0.3,
                    },
                    {
                        label: 'Fat (g)',
                        data: fat,
                        borderColor: '#9B59B6',
                        pointRadius: 4,
                        fill: false,
                        tension: 0.3,
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'top' }
                },
                scales: {
                    y: {
                        beginAtZero: false,
                        title: { display: true, text: 'kcal / g' }
                    },
                    x: {
                        title: { display: true, text: 'Date' }
                    }
                }
            }
        });
    </script>

{% endblock %}
