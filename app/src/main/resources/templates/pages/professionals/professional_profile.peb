<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <link rel="stylesheet" href="/static/css/style.css">
    <style>
        .profile-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }

        .profile-header {
            border: 2px solid #8C7B6A;
            padding: 20px;
            background: #ffffff;
            margin-bottom: 20px;
        }

        .profile-title {
            font-size: 28px;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }

        .profile-info {
            font-size: 18px;
            color: #333;
            margin: 6px 0;
        }

        .profile-form {
            border: 2px solid #8C7B6A;
            padding: 20px;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .profile-section {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .profile-label {
            font-size: 18px;
            font-weight: 600;
            color: #333;
        }

        .profile-form input,
        .profile-form textarea {
            padding: 10px;
            border: 2px solid #8C7B6A;
            border-radius: 4px;
            font-size: 16px;
        }

        .profile-form input:focus,
        .profile-form textarea:focus {
            outline: 3px solid #A94F24;
            border-color: #A94F24;
        }

        .profile-form textarea {
            resize: vertical;
            min-height: 100px;
        }

        .update-button {
            padding: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            background: #A94F24;
            color: white;
            border: none;
        }

        .update-button:hover {
            background: #A94E2E;
        }
    </style>
</head>
<body>
    {% include "components/navbar.peb" %}

    <main class="main-content">
        <div class="profile-container">

            <div class="profile-header">
                <h1 class="profile-title">Profile</h1>

                {% if userinfo is not null %}
                    <p class="profile-info">Professional ID: {{ userinfo.professional_id }}</p>
                    {% if email is defined %}
                        <p class="profile-info">Email: {{ email }}</p>
                    {% endif %}
                    <p class="profile-info">Name: {{ userinfo.first_name }} {{ userinfo.second_name }}</p>
                {% else %}
                    <p class="profile-info">No profile information found.</p>
                {% endif %}
            </div>

            <form method="post" action="/professional-profile-update" class="profile-form">

                <div class="profile-section">
                     <label for="job_title" class="profile-label">Job Title</label>
                    <input id="job_title" type="text" name="job_title" value="{{ userinfo.job_title }}">
                </div>

                <div class="profile-section">
                    <label for="organisation" class="profile-label">Organisation</label>
                    <input id="organisation" type="text" name="organisation" value="{{ userinfo.organisation }}">
                </div>

                <div class="profile-section">
                    <label for="bio" class="profile-label">Bio</label>
                    <textarea id="bio" name="bio">{{ userinfo.bio }}</textarea>
                </div>

                <button type="submit" class="update-button">Update</button>

            </form>
        </div>
    </main>
</body>
</html>
